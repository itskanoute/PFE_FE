# Serveur
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=edumanage

# CORS (URL du frontend Vite)
CORS_ORIGIN=http://localhost:5173

# URL du frontend (liens de réinitialisation mot de passe)
FRONTEND_URL=http://localhost:5173

# JWT — clé secrète pour signer les tokens (changez en production)
JWT_SECRET=changez_cette_cle_secrete_en_production

# Email SMTP (Gmail pour tests)
# 1. Activez la validation en 2 étapes sur le compte Google
# 2. Créez un "Mot de passe d'application" : https://myaccount.google.com/apppasswords
# 3. Collez-le dans SMTP_PASS (pas le mot de passe Gmail normal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kanoutecoumba00@gmail.com
SMTP_PASS=
SMTP_FROM=EduManage <kanoutecoumba00@gmail.com>
